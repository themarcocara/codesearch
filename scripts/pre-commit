#!/bin/bash
# Pre-commit hook: format Rust code only.
#
# Runs `cargo fmt` and stages any reformatting so CI's fmt-check can't fail.
#
# This hook deliberately does NOT bump the version or build a binary. It used
# to auto-bump the Cargo.toml patch version and run `cargo build` on every
# feature-branch commit, which blocked each commit for minutes (a debug build
# nobody deploys) and made the deployed binary constantly drift from HEAD.
#
# The auto-bump was also redundant: build.rs already appends a unique
# "+<commit_count>" suffix (git rev-list --count HEAD) to every build, so each
# commit is uniquely identifiable without churning the base version. The base
# version in Cargo.toml is now bumped deliberately at release time — see
# RELEASING.md.

set -e

echo "pre-commit: running cargo fmt..."
cargo fmt --all --quiet 2>/dev/null || cargo fmt --all --quiet

FMT_CHANGED=$(git diff --name-only -- '*.rs')
if [ -n "$FMT_CHANGED" ]; then
    git add -- '*.rs'
    echo "pre-commit: staged rustfmt changes ($FMT_CHANGED)"
fi

exit 0
